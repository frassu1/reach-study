---

<section class="section section--alt" id="video">
  <div class="section-inner">
    <h2 class="section-heading">Meet Dr. Rassu</h2>
    <div class="video-container" role="img" aria-label="Placeholder for a video introduction from Dr. Fenan Rassu about the REACH Study">
      <div class="video-placeholder">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="12" cy="12" r="11" stroke="var(--white)" stroke-width="1.5" fill="none"/>
          <polygon points="10,7 18,12 10,17" fill="var(--white)"/>
        </svg>
        <p class="video-message">Video coming soon</p>
        <p class="video-sub">A short introduction from Dr. Fenan Rassu about the REACH Study</p>
      </div>
    </div>
  </div>
</section>

<style>
  .video-container {
    margin-top: 1.5rem;
  }

  .video-placeholder {
    background: linear-gradient(135deg, var(--jhm-blue), var(--jhm-medium-blue));
    border-radius: 12px;
    aspect-ratio: 16 / 9;
    max-width: 640px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    cursor: default;
    color: var(--white);
  }

  .video-message {
    font-size: 1.15rem;
    font-weight: 600;
    margin: 0;
  }

  .video-sub {
    font-size: 0.9rem;
    opacity: 0.8;
    text-align: center;
    max-width: 300px;
    margin: 0;
  }
</style>
