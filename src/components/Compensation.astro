---

<section class="section section--alt" id="compensation">
  <div class="section-inner">
    <h2 class="section-heading">You'll be paid for your time</h2>
    <div class="compensation-card">
      <p class="amount-highlight">$175</p>
      <p class="amount">in Amazon gift cards for taking part in the study.</p>
      <p class="insurance-note">The psychology visits are covered by your insurance at no cost to you.</p>
    </div>
  </div>
</section>

<style>
  .compensation-card {
    background-color: var(--white);
    border-left: 5px solid var(--jhm-gold);
    border-radius: 8px;
    padding: 2rem;
    margin-top: 1rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    text-align: center;
  }

  .amount-highlight {
    font-size: 3.5rem;
    font-weight: 800;
    color: var(--jhm-blue);
    line-height: 1.1;
    margin-bottom: 0.25rem;
  }

  .amount {
    font-size: 1.15rem;
    margin-bottom: 1rem;
    color: var(--text-dark);
  }

  .insurance-note {
    margin: 0;
    color: var(--jhm-medium-blue);
  }
</style>
