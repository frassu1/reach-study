---
---

<footer class="footer">
  <div class="footer-inner">
    <img
      src="/images/jhm-logo.png"
      alt="Johns Hopkins Medicine logo"
      class="footer-logo"
      width="300"
      height="80"
      loading="lazy"
    />
    <p class="footer-title">REACH Study — Johns Hopkins School of Medicine</p>
    <div class="footer-details">
      <p>Principal Investigator: Fenan Rassu, PhD</p>
      <p>IRB Number: IRB00520129</p>
      <p>Study Title: REACH Study — Aim 3</p>
    </div>
    <p class="footer-copyright">&copy; {new Date().getFullYear()} Johns Hopkins University. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--white);
    color: var(--jhm-blue);
    padding: 2.5rem 1.5rem;
    text-align: center;
    border-top: 3px solid var(--jhm-light-blue-bg);
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .footer-logo {
    max-width: 250px;
    height: auto;
    margin: 0 auto 1.5rem;
  }

  @media (min-width: 768px) {
    .footer-logo {
      max-width: 300px;
    }
  }

  .footer-title {
    font-weight: 700;
    font-size: 1.1rem;
    margin-bottom: 1rem;
  }

  .footer-details p {
    font-size: 0.9rem;
    margin-bottom: 0.3rem;
    color: var(--jhm-medium-blue);
  }

  .footer-copyright {
    margin-top: 1.5rem;
    font-size: 0.8rem;
    color: var(--jhm-light-blue);
  }
</style>
